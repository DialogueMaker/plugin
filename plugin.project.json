{
  "name": "Dialogue Maker",
  "tree": {
    "$className": "DataModel",
    "ServerStorage": {
      "DialoguePluginScript": {
        "$path": "src/DialoguePluginScript",
        "Packages": {
          "$path": "Packages"
        },
        "DialogueClientScript": {
          "$properties": {
            "Enabled": false
          },
          "$path": "src/DialogueClientScript",
          "Packages": {
            "$path": "Packages"
          }
        }
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "DialogueClientScript": {
          "$path": "src/DialogueClientScript",
          "Packages": {
            "$path": "Packages"
          }
        }
      }
    }
  }
}